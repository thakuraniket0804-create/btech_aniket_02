// Online C compiler to run C program online
#include <stdio.h>

int main() 
{
    int a[3][2],i,j;
    printf("enter the matrix elements\n");
    for(i=0;i<3;i++)
    {
        for(j=0;j<2;j++)
        {
            scanf("%d" , &a[i][j]);
        }
    }
    printf("matrix elements\n");
    for(i=0;i<3;i++)
    {
        for(j=0;j<2;j++)
        {
            printf("%d\n" , a[i][j]);
        }
        printf("\n");
    }

    return 0;
}
