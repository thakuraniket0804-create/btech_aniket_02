// Online C compiler to run C program online
#include <stdio.h>
void swap_ref(int* , int*);
int main() 
{
    int a,b;
    printf("enter a & b \n");
    scanf("%d%d" , &a,&b);
    printf(" before swaping\n");
    printf("a=%d\t b=%d" , a,b);
    swap_ref(&a , &b);
    printf("after swaping\n");
    printf("a=%d\t b=%d" , a,b);

    return 0;
}
    void swap_ref(int*x , int*y)
{
    int t;
    
