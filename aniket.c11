// Online C compiler to run C program online
#include <stdio.h>
void swap_value(int,int);//functionprototype
int main() 
{
    int a,b;
    printf("enter two values");
    scanf("%d%d" ,&a,&b);
    swap_value(a,b); //function calling(call by value)
    printf("\n brfore swaping\n");
    printf("a=%d\t b=%d" ,a,b );

    return 0;
}
    void swap_value(int x, int y)
    {
    int temp;
    temp=x;
    x=y;
    y=temp;
    printf("\nafter swaping\n");
    printf("a=%d\tb=%d" , x,y);
    }
